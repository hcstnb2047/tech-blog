---
// 記事一覧トップ。各記事へ 1 タップで遷移できるリスト。
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_NAME, SITE_DESCRIPTION } from '../config';
import { formatDateJa } from '../utils/date';
import { readingTimeMin } from '../utils/readingTime';

const articles = (await getCollection('articles')).sort(
  (a, b) =>
    new Date(b.data.publishedAt).valueOf() -
    new Date(a.data.publishedAt).valueOf()
);
---

<BaseLayout title={SITE_NAME} description={SITE_DESCRIPTION}>
  {/* ヒーロー: サイト名を主役級のタイポに・短いタグライン（清潔リッチ / zero-JS） */}
  <section class="mb-10 border-b border-border pb-8">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">{SITE_NAME}</h1>
    <p class="mt-3 text-base text-muted">{SITE_DESCRIPTION}</p>
  </section>
  {
    articles.length === 0 ? (
      <p class="text-muted">記事はまだありません。</p>
    ) : (
      <ul class="divide-y divide-border">
        {articles.map((article) => (
          <li class="group relative -mx-4 rounded-lg px-4 py-6 transition-colors group-hover:bg-accent/5">
            {/* stretched-link: カード全体を 1 タップ可能に（リンク文言はタイトルのみ＝a11y維持）。
                rest は text-fg のまま清潔に保ち、hover/focus でリンク affordance を二重提示:
                行全体に淡い accent ティント（bg-accent/5・陰影レス）＋ タイトルに accent＋下線
                （prose リンク規約と統一）。 */}
            <h2 class="text-lg font-semibold tracking-tight">
              <a
                class="text-fg no-underline underline-offset-4 transition-colors after:absolute after:inset-0 group-hover:text-accent group-hover:underline group-focus-within:text-accent group-focus-within:underline"
                href={`/articles/${article.id}/`}
              >
                {article.data.title}
              </a>
            </h2>
            <p class="mt-1 text-sm leading-relaxed text-muted">
              {article.data.description}
            </p>
            <p class="mt-2 flex items-center gap-2 text-sm text-muted">
              <time datetime={article.data.publishedAt}>
                {formatDateJa(article.data.publishedAt)}
              </time>
              <span aria-hidden="true">·</span>
              <span>約{readingTimeMin(article.body)}分</span>
            </p>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
