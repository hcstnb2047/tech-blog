---
// 記事一覧トップ＝ラボノートグリッド（顔）。鮮度（最新の検証）＋分類（タグ）で惹く。
// 設計根拠は DESIGN.md §トップ＝ラボノートグリッド / §タグ（grill 決定台帳 D1–D7）。
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_NAME, SITE_DESCRIPTION } from '../config';
import { formatDateJa } from '../utils/date';
import { readingTimeMin } from '../utils/readingTime';

const articles = (await getCollection('articles')).sort(
  (a, b) =>
    new Date(b.data.publishedAt).valueOf() -
    new Date(a.data.publishedAt).valueOf()
);

// 鮮度の強調: 記事が 3 本以上のときだけ先頭（最新）を全幅にする。
// 2 本以下では片側だけ半幅になり不格好なので等幅グリッドに保つ。
const featuredFullWidth = articles.length >= 3;
---

<BaseLayout title={SITE_NAME} description={SITE_DESCRIPTION}>
  {/* ヒーロー: サイト名（主役級）＋「検証の場」を伝えるタグライン。下のグリッドと border-b で分離。 */}
  <section class="mb-10 border-b border-border pb-8">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">{SITE_NAME}</h1>
    <p class="mt-3 text-base text-muted">{SITE_DESCRIPTION}</p>
  </section>
  {
    articles.length === 0 ? (
      <p class="text-muted">記事はまだありません。</p>
    ) : (
      <ul class="grid gap-6 sm:grid-cols-2">
        {articles.map((article, i) => (
          <li
            class:list={[
              'group relative flex flex-col rounded-xl border border-border bg-card p-5 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:border-fg/20 hover:shadow-md motion-reduce:transform-none motion-reduce:transition-none',
              { 'sm:col-span-2': i === 0 && featuredFullWidth },
            ]}
          >
            {/* 鮮度: 先頭カードに「最新の検証」ラベル（記事から自動導出＝手書き近況欄なし）。 */}
            {i === 0 && (
              <p class="mb-2 text-xs font-medium tracking-wide text-accent">
                最新の検証
              </p>
            )}
            {/* stretched-link: カード全体を 1 タップ可能に（リンク文言はタイトルのみ＝a11y維持）。 */}
            <h2 class="text-lg font-semibold tracking-tight">
              <a
                class="text-fg no-underline underline-offset-4 transition-colors after:absolute after:inset-0 group-hover:text-accent group-hover:underline group-focus-within:text-accent group-focus-within:underline"
                href={`/articles/${article.id}/`}
              >
                {article.data.title}
              </a>
            </h2>
            <p class="mt-1 line-clamp-2 text-sm leading-relaxed text-muted">
              {article.data.description}
            </p>
            {/* タグチップ: 全タグ同色の地味スタイル（虹色禁止・accent不使用）。区別はラベル文字で。 */}
            {article.data.tags.length > 0 && (
              <ul class="mt-3 flex flex-wrap gap-1.5">
                {article.data.tags.map((tag) => (
                  <li class="rounded-md border border-border bg-fg/[0.04] px-1.5 py-0.5 text-xs text-muted">
                    {tag}
                  </li>
                ))}
              </ul>
            )}
            <p class="mt-auto flex items-center gap-2 pt-3 text-sm text-muted">
              <time datetime={article.data.publishedAt}>
                {formatDateJa(article.data.publishedAt)}
              </time>
              <span aria-hidden="true">·</span>
              <span>約{readingTimeMin(article.body)}分</span>
            </p>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
